# ============================================================
# AI Research Assistant — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Application
APP_NAME="AI Research Assistant"
APP_VERSION="1.0.0"
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Database
DATABASE_URL=sqlite+aiosqlite:///./research_assistant.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=research_papers

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# File Storage
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_FILE_SIZE_MB=50

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG
RAG_TOP_K=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
